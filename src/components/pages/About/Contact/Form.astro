---
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Textarea } from "@/components/ui/textarea";
---

<div class="mt-10 rounded-xl bg-primary/10 px-5 py-12 lg:mt-[70px] lg:py-[3.75rem]">
  <form class="mx-auto grid max-w-[610px] gap-8 min-[34.375rem]:grid-cols-2 min-[34.375rem]:gap-x-4 lg:grid-cols-[330px_1fr] lg:gap-x-8">
    <Input
      placeholder="Your name"
      id="name"
      name="name"
      required
      className="h-12 rounded-xl"
    />
    <Input
      type="email"
      placeholder="Your email"
      id="email"
      name="email"
      required
      className="h-12 rounded-xl"
    />
    <Textarea
      placeholder="Message"
      required
      id="message"
      name="message"
      className="min-h-[170px] resize-y rounded-xl min-[34.375rem]:col-span-2"
    />
    <Button
      type="submit"
      className="h-12 max-w-[220px] rounded-xl bg-primary text-primary-foreground shadow-[var(--main---box--shadow)] hover:bg-primary/90 hover:shadow-[var(--main---box--shadow--hover)]"
    >
      Send message
    </Button>
  </form>
</div>
