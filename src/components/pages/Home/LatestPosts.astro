---
import { getCollection } from "astro:content";

import PreviewPost from "@components/PreviewPost.astro";

const allPosts = await getCollection("posts");
const sortedDatePosts = allPosts?.sort(
	(a, b) => Number(new Date(b.data.pubDate)) - Number(new Date(a.data.pubDate)),
);
const featuredPosts = sortedDatePosts.slice(0, 5);

const normalizePostId = (id: string) =>
	id.replace(/\.(md|mdx|markdown)$/i, "").replaceAll(".", "");
---

<section class="latest-posts" aria-labelledby="latest-posts">
  <div class="posts-heading">
    <h2 class="subtitle-section" id="latest-posts">Latest writing</h2>
    <p>
      Recent posts on AI agents, software engineering, and personal growth
      through building.
    </p>
  </div>

  {
    featuredPosts.length > 0 ? (
      <div class="posts-list">
        {featuredPosts.map(({ data, id }) => {
          const slug = normalizePostId(id);

          return (
            <PreviewPost
              title={data.title}
              description={data.shortDesc}
              date={data.pubDate}
              topics={data.categories}
              slug={slug}
              lang={data.lang}
            />
          );
        })}
      </div>
    ) : (
      <h3 class="no-posts">New posts are on the way.</h3>
    )
  }
</section>

<style>
  .latest-posts {
    display: flex;
    flex-direction: column;
    gap: var(--space-9);
    max-width: var(--layout-max-width);
    margin-inline: auto;
  }

  .posts-heading {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .subtitle-section {
    color: var(--text-primary);
    font-size: var(--font-size-xl);
    line-height: var(--leading-heading);
    margin: 0;
  }

  .posts-heading p {
    margin: 0;
    max-width: var(--measure-section-max);
    color: var(--text-secondary);
    font-size: var(--font-size-base);
    line-height: var(--leading-copy-compact);
  }

  .posts-list {
    display: grid;
    gap: var(--space-5);
  }

  .no-posts {
    font-size: var(--font-size-xl);
    line-height: var(--leading-heading);
    color: var(--text-secondary);
    margin: 0;
  }

  @media screen and (min-width: 68.75rem) {
    .posts-list {
      gap: var(--space-6);
    }
  }
</style>
