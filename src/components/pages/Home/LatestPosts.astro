---
import { getCollection } from "astro:content";

import PreviewPost from "@components/PreviewPost.astro";

const allPosts = await getCollection("posts");
const sortedDatePosts = allPosts?.sort(
	(a, b) => Number(new Date(b.data.pubDate)) - Number(new Date(a.data.pubDate)),
);
const featuredPosts = sortedDatePosts.slice(0, 5);

const normalizePostId = (id: string) =>
	id.replace(/\.(md|mdx|markdown)$/i, "").replaceAll(".", "");
---

<section class="flex flex-col gap-9 max-w-[var(--layout-max-width)] mx-auto" aria-labelledby="latest-posts">
  <div class="flex flex-col gap-3">
    <h2 class="text-ink text-xl leading-heading m-0" id="latest-posts">Latest writing</h2>
    <p class="m-0 max-w-[var(--measure-section-max)] text-ink-muted text-base leading-copy-compact">
      Recent posts on AI agents, software engineering, and personal growth
      through building.
    </p>
  </div>

  {
    featuredPosts.length > 0 ? (
      <div class="grid gap-5 desktop:gap-6">
        {featuredPosts.map(({ data, id }) => {
          const slug = normalizePostId(id);

          return (
            <PreviewPost
              title={data.title}
              description={data.shortDesc}
              date={data.pubDate}
              topics={data.categories}
              slug={slug}
              lang={data.lang}
            />
          );
        })}
      </div>
    ) : (
      <h3 class="text-xl leading-heading text-ink-muted m-0">New posts are on the way.</h3>
    )
  }
</section>
