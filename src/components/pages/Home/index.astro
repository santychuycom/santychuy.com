---
import HeroSection from "./Hero.astro";
import LatestPostsSection from "./LatestPosts.astro";

const quickFacts = [
	{ label: "Role", value: "Software Engineer" },
	{ label: "Based in", value: "Hermosillo, Mexico" },
	{ label: "Focus", value: "AI agents, web platforms, and DX" },
	{ label: "Currently", value: "Building and documenting santychuy.com v2" },
];
---

<>
  <HeroSection />

  <section class="quick-context" aria-labelledby="quick-context-title">
    <h2 class="quick-context-title" id="quick-context-title">Quick context</h2>
    <ul class="facts-list">
      {
        quickFacts.map((fact) => (
          <li class="fact-item">
            <span class="fact-label">{fact.label}</span>
            <span class="fact-value">{fact.value}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <LatestPostsSection />
</>

<style>
  .quick-context {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 66rem;
    margin-inline: auto;
  }

  .quick-context-title {
    font-size: clamp(1.3rem, 1.6vw, 1.7rem);
    color: var(--primary---green--6);
  }

  .facts-list {
    list-style: none;
    display: grid;
    gap: 0.9rem;
    padding: 0;
    margin: 0;

    @media screen and (min-width: 48rem) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .fact-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--primary---green--10--alpha--2);
    border-radius: 0.9rem;
    background-color: var(--main---background--alpha);
  }

  .fact-label {
    font-size: 0.88rem;
    color: var(--neutrals---black--7);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .fact-value {
    font-size: 1rem;
    color: var(--neutrals---black--2);
  }
</style>
