---
export const prerender = false;

import Badge from "@components/Badge.astro";
import ViewsIcon from "@components/icons/views.astro";
import ShareActions from "@components/pages/Blog/ShareActions";
import type { Post } from "@schemas/post";

interface Props {
	post: Post;
	id: string;
}

const { post, id } = Astro.props;

const runtime = Astro.locals.runtime;

// https://docs.astro.build/en/guides/integrations-guide/cloudflare/#cloudflare-runtime
let views = 0;

try {
	const res = await fetch(
		`https://umami.santychuy.com/api/websites/${import.meta.env.UMAMI_WEBSITE_ID}/pageviews?startAt=1750885650&endAt=${Date.now()}&unit=hour&timezone=America/Los_Angeles&url=/blog/${id}`,
		{
			headers: {
				Authorization: `Bearer ${import.meta.env.PROD ? runtime.env.UMAMI_AUTH_TOKEN : import.meta.env.UMAMI_AUTH_TOKEN}`,
			},
		},
	);

	if (!res.ok) {
		console.error("Umami API error:", res.status, res.statusText);
	} else {
		const data = await res.json();

		// Check if data has the expected structure
		if (
			data?.pageviews &&
			Array.isArray(data.pageviews) &&
			data.pageviews.length > 0
		) {
			views = data.pageviews[0].y ?? 0;
		}
	}
} catch (error) {
	console.error("Error fetching Umami pageviews:", error);
}

const title = post.title;
const authorImage = post.author.img ?? "/imgs/profile.jpg";
const publishedDateISO = post.pubDate.toISOString();
const publishedDateLabel = new Intl.DateTimeFormat(
	post.lang === "es" ? "es-MX" : "en-US",
	{
		dateStyle: "long",
	},
).format(post.pubDate);
const updatedDateISO = post.updatedDate?.toISOString();
const updatedDateLabel = post.updatedDate
	? new Intl.DateTimeFormat(post.lang === "es" ? "es-MX" : "en-US", {
			dateStyle: "long",
		}).format(post.updatedDate)
	: null;
const publishedLabel = post.lang === "es" ? "Publicado" : "Published";
const updatedLabel = post.lang === "es" ? "Actualizado" : "Updated";
const shareLabel = post.lang === "es" ? "Compartir" : "Share";
const readsLabel = post.lang === "es" ? "lecturas" : "reads";
---

<article class="post-article">
  <img src={post.image} alt={post.imageAlt} class="blog-img" />

  <div class="content">
    <div class="blog-content">
      <h1 class="title">{title}</h1>

      {post.shortDesc && <p class="short-desc">{post.shortDesc}</p>}

      <div class="date-block">
        <p class="date-item">
          <span>{publishedLabel}</span>
          <time class="date" datetime={publishedDateISO}>{publishedDateLabel}</time>
        </p>

        {
          updatedDateLabel && updatedDateISO && (
            <p class="date-item">
              <span>{updatedLabel}</span>
              <time class="date" datetime={updatedDateISO}>{updatedDateLabel}</time>
            </p>
          )
        }
      </div>

      <div class="share-mobile">
        <p>{shareLabel}</p>
        <ShareActions title={title} layout="mobile" client:load />
        <p class="reads-mobile">{views} {readsLabel}</p>
      </div>

      <div class="info-container">
        <div class="author-container">
          <img
            src={authorImage}
            alt={`${post.author.name} profile`}
            class="author-img"
          />
          <p class="author-name">{post.author.name}</p>
        </div>
        <div class="tags-container">
          {post.categories.map((category: string) => <Badge title={category} />)}
        </div>
      </div>

      <slot />
    </div>

    <aside class="utility-column" aria-label="Article actions">
      <ShareActions title={title} layout="desktop" client:load />
      <span class="views-content">
        <ViewsIcon />
        <span class="views">{views}</span>
      </span>
    </aside>
  </div>
</article>

<style>
  .post-article {
    max-width: 75rem;
    margin-inline: auto;
    padding-inline: 1rem;

    @media screen and (min-width: 34.375rem) {
      padding-inline: 1.5rem;
    }
  }

  .blog-img {
    width: 100%;
    object-fit: cover;
    margin-block-end: 2.8rem;
    border-radius: 1rem;
    border: 1px solid var(--primary---green--10--alpha--2);

    @media screen and (min-width: 68.75rem) {
      aspect-ratio: 16 / 8;
      margin-block-end: 4rem;
    }
  }

  .content {
    position: relative;
    display: flex;
    gap: 1.2rem;

    @media screen and (min-width: 68.75rem) {
      align-items: flex-start;
      gap: 2.5rem;
    }
  }

  .blog-content {
    flex: 1;
    min-width: 0;
    max-width: 44rem;
    margin-inline: auto;
  }

  .title {
    margin-block-end: 0.8rem;
    line-height: 1.08;
    text-wrap: balance;
  }

  .short-desc {
    margin: 0;
    font-size: clamp(1.05rem, 2.3vw, 1.25rem);
    color: var(--neutrals---black--4);
    line-height: 1.7;
  }

  .date-block {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    margin-block-start: 1rem;

    .date-item {
      margin: 0;
      display: inline-flex;
      gap: 0.4rem;
      font-size: 0.9rem;
      color: var(--neutrals---black--6);
    }

    .date {
      color: var(--neutrals---black--4);
    }
  }

  .share-mobile {
    margin-block-start: 1.15rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.7rem;

    p {
      margin: 0;
      color: var(--neutrals---black--6);
      font-size: 0.88rem;
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }

    .reads-mobile {
      text-transform: none;
      letter-spacing: 0;
      font-size: 0.92rem;
      color: var(--neutrals---black--5);
    }

    @media screen and (min-width: 68.75rem) {
      display: none;
    }
  }

  .utility-column {
    display: none;

    @media screen and (min-width: 68.75rem) {
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      align-items: center;
      position: sticky;
      top: 6rem;
    }
  }

  .views-content {
    display: none;

    @media screen and (min-width: 68.75rem) {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      background-color: var(--primary---green--10--alpha--2);
      border: 1px solid var(--primary---green--10--alpha--2);
      border-radius: 999px;
      padding: 0.4rem 0.65rem;
      color: var(--neutrals---black--4);
      font-size: 0.85rem;
      font-weight: 600;
    }
  }

  .views {
    line-height: 1;
  }

  .info-container {
    display: flex;
    flex-direction: column;
    margin-block-start: 1.6rem;
    margin-block-end: 2.4rem;
    gap: 1rem;

    @media screen and (min-width: 68.75rem) {
      flex-direction: row;
    }
  }

    .author-container {
    display: flex;
    align-items: center;
    gap: 0.75rem;

    .author-img {
      width: 3rem;
      height: 3rem;
      border-radius: 50%;
      object-fit: cover;
      margin-block-start: 0;
      border: 1px solid var(--primary---green--10--alpha--2);
    }

    .author-name {
      font-weight: 700;
      color: var(--neutrals---black--1);
      margin-block-end: 0;
    }
  }

  .tags-container {
    display: flex;
    flex-wrap: wrap;
    flex: 1;
    align-items: center;
    gap: 0.5rem;

    @media screen and (min-width: 68.75rem) {
      justify-content: flex-end;
    }
  }
</style>
