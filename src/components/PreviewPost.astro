---
import Badge from "./Badge.astro";
import ArrowUpRight from "./icons/arrow-up-right.astro";

interface Props {
	title: string;
	date: Date;
	description: string;
	topics: string[];
	slug: string;
	lang?: "en" | "es";
}

const { title, date, description, topics, slug, lang = "en" } = Astro.props;
const dateLabel = new Intl.DateTimeFormat(lang === "es" ? "es-MX" : "en-US", {
	dateStyle: "medium",
}).format(date);
const readLabel = lang === "es" ? "Leer articulo" : "Read article";
---

<article class="post">
  <p class="date">
    <time datetime={date.toISOString()}>{dateLabel}</time>
  </p>

  <h3>
    <a class="post-link" href={`/blog/${slug}`}>{title}</a>
  </h3>

  <p class="description">
    {description}
  </p>

  <div class="badges-container">
    {topics.map((topic) => <Badge title={topic} />)}
  </div>

  <a class="read-link" href={`/blog/${slug}`}>
    {readLabel}
    <ArrowUpRight class="read-arrow" />
  </a>
</article>

<style>
  .post {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    border-radius: var(--shape-radius-lg);
    border: var(--border-width-default) solid var(--border-subtle);
    background-color: var(--surface-elevated);
    box-shadow: var(--elevation-1);
    transition:
      border-color var(--motion-duration-base) var(--motion-ease-standard),
      transform var(--motion-duration-base) var(--motion-ease-standard),
      box-shadow var(--motion-duration-base) var(--motion-ease-standard);

    &:hover {
      transform: translateY(calc(var(--motion-translate-xs) * -1));
      border-color: var(--focus-ring);
      box-shadow: var(--elevation-2);
    }

    &:focus-within {
      border-color: var(--focus-ring);
      box-shadow: 0 0 0 var(--space-1) var(--focus-ring-soft);
    }

    h3 {
      margin: 0;
      font-size: var(--font-size-lg);
      line-height: var(--leading-heading);
      letter-spacing: -0.01em;
    }

    .date {
      color: var(--text-secondary);
      margin: 0;
      font-size: var(--font-size-xs);
      line-height: var(--leading-tight);
    }

    .description {
      color: var(--text-secondary);
      margin: 0;
      line-height: var(--leading-copy-compact);
      font-size: var(--font-size-base);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      max-width: var(--measure-card-copy-max);
    }

    .badges-container {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--space-2);
      margin-block-start: var(--space-1);
    }

    .post-link {
      color: var(--text-primary);
      text-decoration: none;

      &:focus-visible {
        outline-offset: var(--focus-outline-offset-sm);
      }
    }

    .read-link {
      color: var(--text-primary);
      font-weight: var(--font-weight-semibold);
      font-size: var(--font-size-sm);
      line-height: var(--leading-tight);
      display: flex;
      flex-direction: row;
      gap: var(--space-1);
      align-items: center;
      width: fit-content;
      margin-block-start: var(--space-2);
      text-decoration: underline;
      text-underline-offset: var(--space-1);
      min-height: var(--touch-target-min);
      padding-inline: var(--space-1);

      .read-arrow {
        rotate: 225deg;
        transition: transform var(--motion-duration-base)
          var(--motion-ease-standard);
      }

      &:hover .read-arrow,
      &:focus-visible .read-arrow {
        transform: translate(var(--motion-translate-xs), var(--motion-translate-xs));
      }

      &:focus-visible {
        outline-offset: var(--focus-outline-offset-sm);
      }
    }
  }

  @media screen and (max-width: 34.374rem) {
    .post {
      padding: var(--space-5);
      gap: var(--space-3);
    }

    .post h3 {
      line-height: var(--leading-heading);
    }

    .post .description {
      line-height: var(--leading-copy-compact);
    }
  }
</style>
