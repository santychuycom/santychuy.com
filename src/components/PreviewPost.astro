---
import Badge from "./Badge.astro";
import ArrowUpRight from "./icons/arrow-up-right.astro";

interface Props {
	title: string;
	date: Date;
	description: string;
	topics: string[];
	slug: string;
	lang?: "en" | "es";
}

const { title, date, description, topics, slug, lang = "en" } = Astro.props;
const dateLabel = new Intl.DateTimeFormat(lang === "es" ? "es-MX" : "en-US", {
	dateStyle: "medium",
}).format(date);
const readLabel = lang === "es" ? "Leer articulo" : "Read article";
---

<article class="post">
  <p class="date">
    <time datetime={date.toISOString()}>{dateLabel}</time>
  </p>

  <h3>
    <a class="post-link" href={`/blog/${slug}`}>{title}</a>
  </h3>

  <p class="description">
    {description}
  </p>

  <div class="badges-container">
    {topics.map((topic) => <Badge title={topic} />)}
  </div>

  <a class="read-link" href={`/blog/${slug}`}>
    {readLabel}
    <ArrowUpRight class="read-arrow" />
  </a>
</article>

<style>
  .post {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    padding: 1.25rem;
    border-radius: 1rem;
    border: 1px solid var(--primary---green--10--alpha--2);
    background-color: var(--main---background--alpha);
    transition:
      border-color 0.2s ease,
      transform 0.2s ease;

    &:hover {
      transform: translateY(-2px);
      border-color: var(--primary---green--6--alpha);
    }

    h3 {
      margin: 0;
      font-size: clamp(1.3rem, 2vw, 1.6rem);
      line-height: 1.2;
    }

    .date {
      color: var(--neutrals---black--7);
      margin: 0;
      font-size: 0.9rem;
    }

    .description {
      font-weight: 500;
      color: var(--neutrals---black--3);
      margin: 0;
      line-height: 1.65;
    }

    .badges-container {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.55rem;
      margin-block-start: 0.3rem;
    }

    .post-link {
      color: var(--neutrals---black--1);
      text-decoration: none;
    }

    .read-link {
      color: var(--neutrals---black--1);
      font-weight: 700;
      display: flex;
      flex-direction: row;
      gap: 4px;
      align-items: center;
      width: fit-content;
      margin-block-start: 0.8rem;
      text-decoration: none;

      .read-arrow {
        rotate: 225deg;
        transition: transform 0.2s ease;
      }

      &:hover .read-arrow,
      &:focus-visible .read-arrow {
        transform: translate(2px, 2px);
      }
    }
  }
</style>
