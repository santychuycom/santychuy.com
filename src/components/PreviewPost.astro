---
import ArrowUpRight from "./icons/arrow-up-right.astro";

interface Props {
	title: string;
	date: Date;
	description: string;
	slug: string;
	lang?: "en" | "es";
}

const { title, date, description, slug, lang = "en" } = Astro.props;
const dateLabel = new Intl.DateTimeFormat(lang === "es" ? "es-MX" : "en-US", {
	dateStyle: "medium",
}).format(date);
const readLabel = lang === "es" ? "Leer articulo" : "Read article";
---

<article class="post">
  <a href={`/blog/${slug}`} class="post-link">
    <div class="post-meta">
      <time class="post-date" datetime={date.toISOString()}>{dateLabel}</time>
      <div class="post-action" aria-hidden="true">
        <span class="read-text">{readLabel}</span>
        <ArrowUpRight class="read-arrow" />
      </div>
    </div>
    
    <div class="post-content">
      <h3>{title}</h3>
      <p class="description">{description}</p>
    </div>
  </a>
</article>

<style>
  .post-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-block: var(--space-4);
    text-decoration: none;
    color: inherit;
    outline: none;
    border-radius: var(--shape-radius-sm);
  }

  /* Focus styles for accessibility */
  .post-link:focus-visible {
    background-color: var(--surface-hover);
    box-shadow: 0 0 0 var(--space-2) var(--surface-hover);
  }

  .post-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .post-date {
    color: var(--text-tertiary);
    font-size: var(--font-size-sm);
    font-family: var(--font-mono, monospace);
  }

  .post-action {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-primary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
  }

  .read-arrow {
    rotate: 225deg;
    width: 0.8em;
    height: 0.8em;
    transition: transform var(--motion-duration-base) var(--motion-ease-standard);
  }

  .post-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .post-content h3 {
    margin: 0;
    font-size: var(--font-size-lg);
    line-height: var(--leading-heading);
    letter-spacing: -0.01em;
    color: var(--text-primary);
    font-weight: var(--font-weight-semibold);
    transition: color var(--motion-duration-base) var(--motion-ease-standard);
  }

  .description {
    margin: 0;
    color: var(--text-tertiary); /* Used tertiary for lighter in light mode, darker in dark mode per vars.css */
    line-height: var(--leading-copy);
    font-size: var(--font-size-sm);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    max-width: var(--measure-card-copy-max);
  }

  /* Hover Effects */
  .post:hover .post-content h3 {
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--border-strong);
  }

  .post:hover .read-arrow {
    transform: translate(var(--space-1), calc(var(--space-1) * -1));
  }

  @media screen and (min-width: 68.75rem) {
    .post-link {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-8);
      padding-block: var(--space-4);
    }

    .post-meta {
      flex: 0 0 120px;
    }

    .post-action {
      opacity: 0;
      transform: translateY(calc(var(--space-1) * -1));
      transition: all var(--motion-duration-base) var(--motion-ease-standard);
      pointer-events: none;
    }

    .post:hover .post-action {
      opacity: 1;
      transform: translateY(0);
    }

    .post-content {
      flex: 1;
    }
  }

  @media screen and (max-width: 34.374rem) {
    .post-link {
      padding-block: var(--space-4);
    }

    .post-action {
      /* On mobile, keep it hidden since there's no hover */
      display: none; 
    }
  }
</style>
