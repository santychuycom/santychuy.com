<div class="flex gap-4 bg-surface-up border border-line rounded-sm px-1 py-1 w-full touch-target">
  <input type="radio" name="tab" id="experience" class="peer/exp sr-only" checked />
  <label for="experience" class="flex justify-center items-center flex-1 cursor-pointer touch-target p-2 text-ink-faint text-sm leading-tight rounded-sm transition-[background-color,color] duration-base ease-standard peer-checked/exp:text-ink peer-checked/exp:bg-surface-dim peer-checked/exp:border peer-checked/exp:border-line-strong peer-checked/exp:font-medium peer-focus-visible/exp:outline-[length:var(--focus-outline-width)] peer-focus-visible/exp:outline-focus peer-focus-visible/exp:outline-offset-[var(--focus-outline-offset-sm)]">Experience</label>

  <input type="radio" name="tab" id="projects" class="peer/proj sr-only" />
  <label for="projects" class="flex justify-center items-center flex-1 cursor-pointer touch-target p-2 text-ink-faint text-sm leading-tight rounded-sm transition-[background-color,color] duration-base ease-standard peer-checked/proj:text-ink peer-checked/proj:bg-surface-dim peer-checked/proj:border peer-checked/proj:border-line-strong peer-checked/proj:font-medium peer-focus-visible/proj:outline-[length:var(--focus-outline-width)] peer-focus-visible/proj:outline-focus peer-focus-visible/proj:outline-offset-[var(--focus-outline-offset-sm)]">Projects</label>

  <input type="radio" name="tab" id="example-projects" class="peer/exproj sr-only" />
  <label for="example-projects" class="flex justify-center items-center flex-1 cursor-pointer touch-target p-2 text-ink-faint text-sm leading-tight rounded-sm transition-[background-color,color] duration-base ease-standard peer-checked/exproj:text-ink peer-checked/exproj:bg-surface-dim peer-checked/exproj:border peer-checked/exproj:border-line-strong peer-checked/exproj:font-medium peer-focus-visible/exproj:outline-[length:var(--focus-outline-width)] peer-focus-visible/exproj:outline-focus peer-focus-visible/exproj:outline-offset-[var(--focus-outline-offset-sm)]">Example Projects</label>
</div>

<script>
  import { activeTab } from '../../stores/tabs';

  function handleTabChange(event: Event) {
    const target = event.target as HTMLInputElement;
    activeTab.set(target.id as 'experience' | 'projects' | 'example-projects');
  }

  document.querySelectorAll('input[type="radio"]').forEach((radio) => {
    radio.addEventListener('change', handleTabChange);
  });
</script>
