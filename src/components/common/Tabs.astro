<div class="tabs">
  <input type="radio" name="tab" id="experience" checked />
  <label for="experience">Experience</label>

  <input type="radio" name="tab" id="projects" />
  <label for="projects">Projects</label>

  <input type="radio" name="tab" id="example-projects" />
  <label for="example-projects">Example Projects</label>
</div>

<script>
  import { activeTab } from '../../stores/tabs';

  function handleTabChange(event: Event) {
    const target = event.target as HTMLInputElement;
    activeTab.set(target.id as 'experience' | 'projects' | 'example-projects');
  }

  document.querySelectorAll('input[type="radio"]').forEach((radio) => {
    radio.addEventListener('change', handleTabChange);
  });
</script>

<style>
  .tabs {
    display: flex;
    gap: var(--space-4);
    background-color: var(--surface-elevated);
    border: var(--border-width-default) solid var(--border-subtle);
    border-radius: var(--shape-radius-sm);
    padding-inline: var(--space-1);
    padding-block: var(--space-1);
    width: 100%;
    min-height: var(--touch-target-min);
  }

  input[type='radio'] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  label {
    display: flex;
    justify-content: center;
    align-items: center;
    flex: 1;
    cursor: pointer;
    min-height: var(--touch-target-min);
    padding: var(--space-2);
    color: var(--text-tertiary);
    font-size: var(--font-size-sm);
    line-height: var(--leading-tight);
    border-radius: var(--shape-radius-sm);
    transition:
      background-color var(--motion-duration-base) var(--motion-ease-standard),
      color var(--motion-duration-base) var(--motion-ease-standard);
  }

  input[type='radio']:checked + label {
    color: var(--text-primary);
    background-color: var(--surface-muted);
    border-radius: var(--shape-radius-sm);
    border: var(--border-width-default) solid var(--border-strong);
    font-weight: var(--font-weight-medium);
  }

  input[type='radio']:focus-visible + label {
    outline: var(--focus-outline-width) solid var(--focus-ring);
    outline-offset: var(--focus-outline-offset-sm);
  }
</style>
