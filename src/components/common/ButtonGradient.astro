---
import ArrowDown from "@components/icons/arrow-down.astro";

interface Props {
	label: string;
}

const { label } = Astro.props;
---

<button class="group relative inline-flex overflow-hidden mt-10 rounded-pill px-1 py-1 border-none shadow-1 transition-shadow duration-base ease-standard focus-visible:outline-none focus-visible:shadow-[0_0_0_var(--space-1)_var(--focus-ring-soft)] hover:shadow-2">
  <span class="gradient-spinner"></span>
  <span class="relative inline-flex gap-2 cursor-pointer items-center justify-center h-full w-full touch-target rounded-pill px-4 py-2 text-sm font-semibold leading-tight text-surface-up bg-ink backdrop-blur-[var(--effect-blur-overlay)]">
    {label}
    <ArrowDown class="w-auto h-[1em] group-hover:animate-bounce-arrow" />
  </span>
</button>

<style>
  .gradient-spinner {
    position: absolute;
    inset: -1000%;
    animation: spin var(--motion-duration-spin) linear infinite;
    background-image: conic-gradient(
      from 90deg at 50% 50%,
      var(--text-primary) 0%,
      var(--paper-accent) 50%,
      var(--text-primary) 100%
    );
  }
</style>
