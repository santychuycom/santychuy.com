---
import ArrowDown from "@components/icons/arrow-down.astro";

interface Props {
	label: string;
}

const { label } = Astro.props;
---

<button>
  <span class="gradient"></span>
  <span class="content">
    {label}
    <ArrowDown class="icon-arrow" />
  </span>
</button>

<style>
  button {
    position: relative;
    display: inline-flex;
    overflow: hidden;
    margin-block-start: var(--space-10);
    border-radius: var(--shape-radius-pill);
    padding-inline: var(--space-1);
    padding-block: var(--space-1);
    border: none;
    box-shadow: var(--elevation-1);
    transition: box-shadow var(--motion-duration-base) var(--motion-ease-standard);

    &:focus-visible {
      outline: none;
      box-shadow: 0 0 0 var(--space-1) var(--focus-ring-soft);
    }

    &:hover {
      box-shadow: var(--elevation-2);
    }

    &:hover .icon-arrow {
      animation: bounce var(--motion-duration-slow) var(--motion-ease-standard);
    }
  }

  .gradient {
    position: absolute;
    inset: -1000%;
    animation: spin var(--motion-duration-spin) linear infinite;
    background-image: conic-gradient(
      from 90deg at 50% 50%,
      var(--text-primary) 0%,
      var(--paper-accent) 50%,
      var(--text-primary) 100%
    );
  }

  .content {
    display: inline-flex;
    gap: var(--space-2);
    cursor: pointer;
    align-items: center;
    justify-content: center;
    height: 100%;
    width: 100%;
    min-height: var(--touch-target-min);
    border-radius: var(--shape-radius-pill);
    padding-inline: var(--space-4);
    padding-block: var(--space-2);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    line-height: var(--leading-tight);
    color: var(--surface-elevated);
    background-color: var(--text-primary);
    backdrop-filter: blur(var(--effect-blur-overlay));
  }
</style>
