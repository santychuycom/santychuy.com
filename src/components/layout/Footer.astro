---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <p>&copy; {year} Santiago Carrasco. Building in public.</p>
</footer>

<style>
  .site-footer {
    width: min(
      var(--layout-shell-max-width),
      calc(100% - var(--layout-shell-edge-mobile))
    );
    margin-inline: auto;
    margin-block-start: auto;
    padding-block: var(--space-5) var(--space-9);
    border-top: var(--border-width-default) solid var(--border-subtle);

    @media screen and (min-width: 34.375rem) {
      width: min(
        var(--layout-shell-max-width),
        calc(100% - var(--layout-shell-edge-tablet))
      );
    }
  }

  p {
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    line-height: var(--leading-copy-compact);
  }
</style>
