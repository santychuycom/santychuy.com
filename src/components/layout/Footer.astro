---
import SantychuyLogo from "@components/icons/santychuyISO.astro";
import type { Locale } from "@ts/i18n";
import { getLocaleMessages } from "../../i18n";

interface Props {
	lang?: Locale;
}

const { lang = "en" } = Astro.props;
const messages = getLocaleMessages(lang);
const year = new Date().getFullYear();
---

<footer class="shell-width mt-auto py-9 border-t border-line">
  <div class="flex flex-col items-center justify-center gap-4 text-center">
    <SantychuyLogo class="w-8 h-auto text-ink-faint" />
    <p class="m-0 text-sm text-ink-muted leading-copy-compact">&copy; {year} Santiago Carrasco. {messages.footer.tagline}</p>
  </div>
</footer>
