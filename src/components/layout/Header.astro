---
import MoonIcon from "@components/icons/moon.astro";
import SantychuyLogo from "@components/icons/santychuyISO.astro";
import SunIcon from "@components/icons/sun.astro";
---

<header class="flex items-center justify-between gap-4 shell-width py-5 border-b border-line desktop:py-6">
  <a href="/" class="inline-flex items-center justify-center rounded-pill text-ink transition-[transform,color] duration-base ease-standard hover-lift hover:text-brand focus-ring" aria-label="Go to homepage">
    <SantychuyLogo class="w-[var(--brand-logo-size)] h-auto desktop:w-[var(--brand-logo-size-desktop)]" />
  </a>

  <button
    class="group touch-target inline-flex items-center gap-2 p-1 border-none rounded-pill bg-transparent cursor-pointer focus-ring"
    type="button"
    data-theme-toggle
    data-theme="light"
    aria-label="Switch to dark mode"
    aria-pressed="false"
  >
    <SunIcon class="w-[18px] h-[18px] text-ink-faint transition-colors duration-base ease-standard group-data-[theme=light]:text-ink" aria-hidden="true" />
    <span class="switch-track relative w-9 h-5 rounded-pill bg-line shadow-[inset_0_1px_2px_rgb(0_0_0/0.1)] transition-colors duration-base ease-standard group-hover:bg-line-strong group-data-[theme=dark]:bg-brand group-data-[theme=dark]:hover:bg-brand" aria-hidden="true">
      <span class="absolute top-0.5 left-0.5 w-4 h-4 rounded-pill bg-surface-up shadow-[0_1px_3px_rgb(0_0_0/0.15)] translate-x-0 transition-transform duration-base ease-[cubic-bezier(0.5,-0.3,0.1,1.5)] motion-reduce:transition-[transform_0.01ms] group-data-[theme=dark]:translate-x-4"></span>
    </span>
    <MoonIcon class="w-[18px] h-[18px] text-ink-faint transition-colors duration-base ease-standard group-data-[theme=dark]:text-ink" aria-hidden="true" />
    <span class="sr-only" data-theme-label>Light</span>
  </button>
</header>
