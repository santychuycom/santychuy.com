---
import "@styles/reset.css";
import "@styles/vars.css";
import "@styles/globals.css";
import "@styles/animations.css";

import { ViewTransitions } from "astro:transitions";
import UmamiTracker from "@components/analytics/UmamiTracker.astro";

interface Props {
	title: string;
	description: string;
	image: string;
	url: string;
	noIndex?: boolean;
	lang?: "en" | "es";
	schema?: Record<string, unknown> | Record<string, unknown>[];
	alternates?: Partial<Record<"en" | "es" | "x-default", string>>;
}

const {
	title,
	description,
	image,
	url,
	noIndex,
	lang = "en",
	schema,
	alternates,
} = Astro.props;

const structuredData = schema
	? Array.isArray(schema)
		? schema
		: [schema]
	: [];

const ogLocale = lang === "es" ? "es_MX" : "en_US";
const hreflangAlternates = {
	[lang]: url,
	"x-default": url,
	...(alternates ?? {}),
};
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/Satoshi-Variable.woff2"
      crossorigin
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
      {`${title} - Santiago Carrasco (Santychuy)`}
    </title>
    <link rel="canonical" href={url} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Santychuy Blog RSS"
      href="/feed.xml"
    />
    <link rel="alternate" type="text/plain" title="LLMs Manifest" href="/llms.txt" />
    <link rel="alternate" type="text/plain" title="LLMs Full Index" href="/llms-full.txt" />
    {hreflangAlternates.en && <link rel="alternate" hreflang="en" href={hreflangAlternates.en} />}
    {hreflangAlternates.es && <link rel="alternate" hreflang="es" href={hreflangAlternates.es} />}
    {hreflangAlternates["x-default"] && (
      <link rel="alternate" hreflang="x-default" href={hreflangAlternates["x-default"]} />
    )}
    {noIndex && <meta name="robots" content="noindex" />}
    <ViewTransitions />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="Santiago Carrasco Blog" />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@santychuy" />
    <meta name="twitter:creator" content="@santychuy" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    {structuredData.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    <UmamiTracker />
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
