---
import "@styles/reset.css";
import "@styles/vars.css";
import "@styles/globals.css";
import "@styles/animations.css";

import { ViewTransitions } from "astro:transitions";
import Footer from "@components/layout/Footer.astro";
import Header from "@components/layout/Header.astro";

interface Props {
	title: string;
	description: string;
	image: string;
	url: string;
	noIndex?: boolean;
}

const { title, description, image, url, noIndex } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/Satoshi-Variable.woff2"
      crossorigin
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
      {`${title} - Santiago Carrasco (Santychuy)`}
    </title>
    {noIndex && <meta name="robots" content="noindex" />}
    <ViewTransitions />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="Santiago Carrasco Blog" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@santychuy" />
    <meta name="twitter:creator" content="@santychuy" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <script
      defer
      src="https://umami.santychuy.com/script.js"
      data-website-id="2f3b8fca-a83a-4d9d-b851-0d70e1a6f43b"></script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <style>
      main {
        width: 100%;
        padding-block-end: 80px;
      }
    </style>
  </body>
</html>
