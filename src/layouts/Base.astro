---
import "@styles/reset.css";
import "@styles/vars.css";
import "@styles/globals.css";
import "@styles/animations.css";

import { ClientRouter } from "astro:transitions";
import UmamiTracker from "@components/analytics/UmamiTracker.astro";
import Footer from "@components/layout/Footer.astro";
import Header from "@components/layout/Header.astro";
import ThemeScript from "@components/ThemeScript.astro";
import { getFeedUrl, type LocaleUrlMap } from "@ts/i18n";

interface Props {
	title?: string;
	description: string;
	url: string;
	noIndex?: boolean;
	lang?: "en" | "es";
	schema?: Record<string, unknown> | Record<string, unknown>[];
	alternates?: Partial<Record<"en" | "es" | "x-default", string>>;
	languageSwitcher?: LocaleUrlMap;
}

const {
	title,
	description,
	url,
	noIndex,
	lang = "en",
	schema,
	alternates,
	languageSwitcher,
} = Astro.props;

const structuredData = schema
	? Array.isArray(schema)
		? schema
		: [schema]
	: [];

const ogLocale = lang === "es" ? "es_MX" : "en_US";
const hreflangAlternates = {
	[lang]: url,
	"x-default": url,
	...(alternates ?? {}),
};
const feedHref = getFeedUrl(lang);
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/Satoshi-Variable.woff2"
      crossorigin
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeScript />
    <title>
      {
        title
          ? `${title} - Santiago Carrasco (Santychuy)`
          : 'Santiago Carrasco (Santychuy)'
      }
    </title>
    <link rel="canonical" href={url} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Santychuy Blog RSS"
      href={feedHref}
    />
    <link rel="alternate" type="text/plain" title="LLMs Manifest" href="/llms.txt" />
    <link rel="alternate" type="text/plain" title="LLMs Full Index" href="/llms-full.txt" />
    {hreflangAlternates.en && <link rel="alternate" hreflang="en" href={hreflangAlternates.en} />}
    {hreflangAlternates.es && <link rel="alternate" hreflang="es" href={hreflangAlternates.es} />}
    {hreflangAlternates['x-default'] && (
      <link rel="alternate" hreflang="x-default" href={hreflangAlternates['x-default']} />
    )}
    {noIndex && <meta name="robots" content="noindex" />}
    <ClientRouter />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta
      property="og:title"
      content={title
        ? `${title} - Santiago Carrasco (Santychuy)`
        : 'Santiago Carrasco (Santychuy)'}
    />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta
      property="og:image"
      content="https://santychuy.com/og-santychuy.png"
    />
    <meta property="og:site_name" content="Santiago Carrasco (Santychuy)" />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@santychuy" />
    <meta name="twitter:creator" content="@santychuy" />
    <meta
      name="twitter:title"
      content={title
        ? `${title} - Santiago Carrasco (Santychuy)`
        : 'Santiago Carrasco (Santychuy)'}
    />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content="https://santychuy.com/og-santychuy.png"
    />
    {structuredData.map((item) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    <UmamiTracker />
  </head>
  <body class="min-h-svh">
    <Header lang={lang} languageSwitcher={languageSwitcher} />
    <main class="w-full max-w-[var(--layout-max-width)] mx-auto flex-1 relative pt-[var(--layout-main-padding-top)] pb-[var(--layout-main-padding-bottom)] px-[var(--layout-gutter-mobile)] tablet:px-[var(--layout-gutter-tablet)] desktop:pt-[var(--layout-main-padding-top-desktop)] desktop:pb-[var(--layout-main-padding-bottom-desktop)] desktop:px-[var(--layout-gutter-desktop)]">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
