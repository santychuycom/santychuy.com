---
import "@styles/reset.css";
import "@styles/vars.css";
import "@styles/globals.css";
import "@styles/animations.css";

import { ViewTransitions } from "astro:transitions";

import Background from "@components/Background.astro";
import Contact from "@components/layout/Contact.astro";
import Footer from "@components/layout/Footer.astro";
import Header from "@components/layout/Header.astro";

interface Props {
	title?: string;
	description: string;
	url: string;
	noIndex?: boolean;
	lang?: "en" | "es";
	schema?: Record<string, unknown> | Record<string, unknown>[];
	alternates?: Partial<Record<"en" | "es" | "x-default", string>>;
}

const {
	title,
	description,
	url,
	noIndex,
	lang = "en",
	schema,
	alternates,
} = Astro.props;

const structuredData = schema
	? Array.isArray(schema)
		? schema
		: [schema]
	: [];

const ogLocale = lang === "es" ? "es_MX" : "en_US";
const hreflangAlternates = {
	[lang]: url,
	"x-default": url,
	...(alternates ?? {}),
};
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/Satoshi-Variable.woff2"
      crossorigin
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
      {
        title
          ? `${title} - Santiago Carrasco (Santychuy)`
          : 'Santiago Carrasco (Santychuy)'
      }
    </title>
    <link rel="canonical" href={url} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Santychuy Blog RSS"
      href="/feed.xml"
    />
    <link rel="alternate" type="text/plain" title="LLMs Manifest" href="/llms.txt" />
    <link rel="alternate" type="text/plain" title="LLMs Full Index" href="/llms-full.txt" />
    {hreflangAlternates.en && <link rel="alternate" hreflang="en" href={hreflangAlternates.en} />}
    {hreflangAlternates.es && <link rel="alternate" hreflang="es" href={hreflangAlternates.es} />}
    {hreflangAlternates['x-default'] && (
      <link rel="alternate" hreflang="x-default" href={hreflangAlternates['x-default']} />
    )}
    {noIndex && <meta name="robots" content="noindex" />}
    <ViewTransitions />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta
      property="og:title"
      content={title
        ? `${title} - Santiago Carrasco (Santychuy)`
        : 'Santiago Carrasco (Santychuy)'}
    />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta
      property="og:image"
      content="https://santychuy.com/og-santychuy.png"
    />
    <meta property="og:site_name" content="Santiago Carrasco (Santychuy)" />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@santychuy" />
    <meta name="twitter:creator" content="@santychuy" />
    <meta
      name="twitter:title"
      content={title
        ? `${title} - Santiago Carrasco (Santychuy)`
        : 'Santiago Carrasco (Santychuy)'}
    />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content="https://santychuy.com/og-santychuy.png"
    />
    {structuredData.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    <script
      defer
      src="https://umami.santychuy.com/script.js"
      data-website-id="2f3b8fca-a83a-4d9d-b851-0d70e1a6f43b"></script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Contact />
    <Footer />
    <Background />
    <style>
      main {
        display: flex;
        flex-direction: column;
        flex: 1;
        padding-block: 120px;
        gap: 10rem;

        @media screen and (min-width: 68.75rem) {
          padding-inline: 4rem;
        }
      }
    </style>
  </body>
</html>
