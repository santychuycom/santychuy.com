---
import "@styles/reset.css";
import "@styles/vars.css";
import "@styles/globals.css";
import "@styles/animations.css";

import { ViewTransitions } from "astro:transitions";
import UmamiTracker from "@components/analytics/UmamiTracker.astro";
import Footer from "@components/layout/Footer.astro";
import Header from "@components/layout/Header.astro";

interface Props {
	title?: string;
	description: string;
	url: string;
	noIndex?: boolean;
	lang?: "en" | "es";
	schema?: Record<string, unknown> | Record<string, unknown>[];
	alternates?: Partial<Record<"en" | "es" | "x-default", string>>;
}

const {
	title,
	description,
	url,
	noIndex,
	lang = "en",
	schema,
	alternates,
} = Astro.props;

const structuredData = schema
	? Array.isArray(schema)
		? schema
		: [schema]
	: [];

const ogLocale = lang === "es" ? "es_MX" : "en_US";
const hreflangAlternates = {
	[lang]: url,
	"x-default": url,
	...(alternates ?? {}),
};
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/Satoshi-Variable.woff2"
      crossorigin
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (() => {
        const key = "theme";
        const dark = "dark";
        const light = "light";
        const root = document.documentElement;

        const getStoredTheme = () => {
          try {
            const value = localStorage.getItem(key);
            return value === dark || value === light ? value : null;
          } catch {
            return null;
          }
        };

        const getSystemTheme = () =>
          window.matchMedia("(prefers-color-scheme: dark)").matches ? dark : light;

        const getPreferredTheme = () => getStoredTheme() ?? getSystemTheme();

        const applyTheme = (theme) => {
          const isDark = theme === dark;
          root.classList.toggle(dark, isDark);
          root.style.colorScheme = isDark ? dark : light;
        };

        const syncToggle = () => {
          const toggle = document.querySelector("[data-theme-toggle]");

          if (!(toggle instanceof HTMLButtonElement)) {
            return;
          }

          const isDark = root.classList.contains(dark);

          toggle.dataset.theme = isDark ? dark : light;
          toggle.setAttribute("aria-pressed", String(isDark));
          toggle.setAttribute(
            "aria-label",
            isDark ? "Switch to light mode" : "Switch to dark mode",
          );

          const label = toggle.querySelector("[data-theme-label]");

          if (label) {
            label.textContent = isDark ? "Dark" : "Light";
          }
        };

        const bindToggle = () => {
          const toggle = document.querySelector("[data-theme-toggle]");

          if (!(toggle instanceof HTMLButtonElement)) {
            return;
          }

          if (toggle.dataset.bound === "true") {
            syncToggle();
            return;
          }

          toggle.dataset.bound = "true";

          toggle.addEventListener("click", () => {
            const nextTheme = root.classList.contains(dark) ? light : dark;

            try {
              localStorage.setItem(key, nextTheme);
            } catch {
              // Ignore storage failures (e.g. privacy mode).
            }

            applyTheme(nextTheme);
            syncToggle();
          });

          syncToggle();
        };

        const applyAndSync = () => {
          applyTheme(getPreferredTheme());
          bindToggle();
        };

        if (root.dataset.themeBootstrapped !== "true") {
          root.dataset.themeBootstrapped = "true";

          document.addEventListener("astro:after-swap", applyAndSync);
          document.addEventListener("astro:page-load", bindToggle);

          const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
          const onSystemThemeChange = () => {
              if (getStoredTheme() === null) {
                applyAndSync();
              }
            };

          if (typeof mediaQuery.addEventListener === "function") {
            mediaQuery.addEventListener("change", onSystemThemeChange);
          } else if (typeof mediaQuery.addListener === "function") {
            mediaQuery.addListener(onSystemThemeChange);
          }
        }

        applyAndSync();
      })();
    </script>
    <title>
      {
        title
          ? `${title} - Santiago Carrasco (Santychuy)`
          : 'Santiago Carrasco (Santychuy)'
      }
    </title>
    <link rel="canonical" href={url} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Santychuy Blog RSS"
      href="/feed.xml"
    />
    <link rel="alternate" type="text/plain" title="LLMs Manifest" href="/llms.txt" />
    <link rel="alternate" type="text/plain" title="LLMs Full Index" href="/llms-full.txt" />
    {hreflangAlternates.en && <link rel="alternate" hreflang="en" href={hreflangAlternates.en} />}
    {hreflangAlternates.es && <link rel="alternate" hreflang="es" href={hreflangAlternates.es} />}
    {hreflangAlternates['x-default'] && (
      <link rel="alternate" hreflang="x-default" href={hreflangAlternates['x-default']} />
    )}
    {noIndex && <meta name="robots" content="noindex" />}
    <ViewTransitions />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta
      property="og:title"
      content={title
        ? `${title} - Santiago Carrasco (Santychuy)`
        : 'Santiago Carrasco (Santychuy)'}
    />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta
      property="og:image"
      content="https://santychuy.com/og-santychuy.png"
    />
    <meta property="og:site_name" content="Santiago Carrasco (Santychuy)" />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@santychuy" />
    <meta name="twitter:creator" content="@santychuy" />
    <meta
      name="twitter:title"
      content={title
        ? `${title} - Santiago Carrasco (Santychuy)`
        : 'Santiago Carrasco (Santychuy)'}
    />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content="https://santychuy.com/og-santychuy.png"
    />
    {structuredData.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    <UmamiTracker />
  </head>
  <body class="min-h-svh">
    <Header />
    <main class="w-full max-w-[var(--layout-max-width)] mx-auto flex-1 relative pt-[var(--layout-main-padding-top)] pb-[var(--layout-main-padding-bottom)] px-[var(--layout-gutter-mobile)] tablet:px-[var(--layout-gutter-tablet)] desktop:pt-[var(--layout-main-padding-top-desktop)] desktop:pb-[var(--layout-main-padding-bottom-desktop)] desktop:px-[var(--layout-gutter-desktop)]">
      <slot />
    </main>
    <Footer />
  </body>
</html>
