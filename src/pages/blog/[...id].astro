---
export const prerender = false;

import { getEntry, render } from "astro:content";
import BlogContent from "@components/pages/Blog/index.astro";
import BlogLayout from "@layouts/Blog.astro";

const { id } = Astro.params;

if (id === undefined) return Astro.redirect("/404");

const normalizedId = id
	.replace(/\.(md|mdx|markdown)$/i, "")
	.replaceAll(".", "");

const entry = await getEntry("posts", normalizedId);

if (entry === undefined) return Astro.redirect("/404");

if (id !== normalizedId) return Astro.redirect(`/blog/${normalizedId}`, 301);

const siteURL = Astro.site ?? Astro.url;
const canonicalURL = entry.data.canonical
	? entry.data.canonical
	: new URL(Astro.url.pathname, siteURL).toString();
const imageURL = new URL(entry.data.image, siteURL).toString();
const authorImageURL = entry.data.author.img
	? new URL(entry.data.author.img, siteURL).toString()
	: undefined;

const articleSchema = {
	"@context": "https://schema.org",
	"@type": "Article",
	headline: entry.data.title,
	description: entry.data.description,
	image: [imageURL],
	datePublished: entry.data.pubDate.toISOString(),
	dateModified: (entry.data.updatedDate ?? entry.data.pubDate).toISOString(),
	inLanguage: entry.data.lang === "es" ? "es-MX" : "en-US",
	articleSection: entry.data.categories,
	mainEntityOfPage: {
		"@type": "WebPage",
		"@id": canonicalURL,
	},
	author: {
		"@type": "Person",
		name: entry.data.author.name,
		image: authorImageURL,
		url: new URL("/", siteURL).toString(),
	},
	publisher: {
		"@type": "Person",
		name: "Santiago Carrasco",
		url: new URL("/", siteURL).toString(),
	},
	...(entry.data.keywords
		? {
				keywords: entry.data.keywords.join(", "),
			}
		: {}),
};

const alternates =
	entry.data.lang === "es"
		? { es: canonicalURL, "x-default": canonicalURL }
		: { en: canonicalURL, "x-default": canonicalURL };

const { Content } = await render(entry);
---

<BlogLayout
  title={entry.data.title}
  description={entry.data.description}
  image={imageURL}
  url={canonicalURL}
  lang={entry.data.lang}
  alternates={alternates}
  schema={articleSchema}
>
  <BlogContent post={entry.data} id={normalizedId}>
    <Content />
  </BlogContent>
</BlogLayout>

<style is:global>
  h1 {
    font-size: clamp(2.1rem, 6vw - 0.5rem, 3.2rem);
  }

  h2,
  h3,
  h4,
  h5 {
    color: var(--primary---green--6);
    margin-block-start: 3rem;
    margin-block-end: 1.35rem;
    line-height: 1.2;
  }

  p {
    margin-block-end: 1.6rem;
    font-size: clamp(1.05rem, 2vw, 1.22rem);
    line-height: 1.85;
  }

  a {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.13em;
  }

  blockquote {
    border-left: 4px solid var(--primary---green--6);
    border-top-left-radius: 4px;
    border-bottom-left-radius: 4px;
    font-style: italic;
    padding-inline-start: 1.4rem;
    padding-block: 1rem;
    margin-block: 2.5rem;
    color: var(--neutrals---black--3);

    p {
      font-size: clamp(1.2rem, 3vw, 1.4rem);
      margin-block: 0;
    }
  }

  hr {
    border-radius: 100%;
    border-color: var(--primary---green--8);
    margin-block-start: 4rem;
    margin-block-end: 3rem;
  }

  code {
    background-color: var(--neutrals---black--10);
    padding-block: 0.2rem;
    padding-inline: 0.4rem;
    border-radius: 8px;
    font-size: clamp(0.9rem, 3vw, 1.1rem);
  }

  pre {
    border-radius: 16px;
    padding-block: 1.2rem;
    padding-inline: 1.1rem;
    margin-block: 2.4rem;
    border: 1px solid var(--primary---green--10--alpha--2);

    code {
      background-color: transparent;
    }
  }

  ol,
  ul {
    padding-inline-start: 2rem;
    margin-block: 1rem;
  }

  ul > li {
    margin-block: 0.5rem;

    &::marker {
      color: var(--primary---green--6);
    }
  }

  img {
    max-width: 100%;
    border-radius: 0.7rem;
    margin-block-start: 2rem;
    margin-block-end: 0.5rem;
  }

  mark {
    color: inherit;
    padding-inline: 0.22em;
    border-radius: 0.25rem;
    background: linear-gradient(
      180deg,
      transparent 18%,
      var(--primary---green--6--alpha--2) 18%,
      var(--primary---green--6--alpha--2) 88%,
      transparent 88%
    );
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }
</style>
