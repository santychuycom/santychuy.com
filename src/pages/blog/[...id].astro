---
export const prerender = false;

import { getEntry, render } from "astro:content";
import Note from "@components/mdx/Note.astro";
import BlogContent from "@components/pages/Blog/index.astro";
import BlogLayout from "@layouts/Blog.astro";

const { id } = Astro.params;

if (id === undefined) return Astro.redirect("/404");

const normalizedId = id
	.replace(/\.(md|mdx|markdown)$/i, "")
	.replaceAll(".", "");

const entry = await getEntry("posts", normalizedId);

if (entry === undefined) return Astro.redirect("/404");

if (id !== normalizedId) return Astro.redirect(`/blog/${normalizedId}`, 301);

const siteURL = Astro.site ?? Astro.url;
const canonicalURL = entry.data.canonical
	? entry.data.canonical
	: new URL(Astro.url.pathname, siteURL).toString();
const imageURL = new URL(entry.data.image, siteURL).toString();
const authorImageURL = entry.data.author.img
	? new URL(entry.data.author.img, siteURL).toString()
	: undefined;

const homeURL = new URL("/", siteURL).toString();

const articleSchema = {
	"@context": "https://schema.org",
	"@type": "Article",
	headline: entry.data.title,
	description: entry.data.description,
	image: [imageURL],
	datePublished: entry.data.pubDate.toISOString(),
	dateModified: (entry.data.updatedDate ?? entry.data.pubDate).toISOString(),
	inLanguage: entry.data.lang === "es" ? "es-MX" : "en-US",
	articleSection: entry.data.categories,
	mainEntityOfPage: {
		"@type": "WebPage",
		"@id": canonicalURL,
	},
	author: {
		"@type": "Person",
		name: entry.data.author.name,
		image: authorImageURL,
		url: homeURL,
	},
	publisher: {
		"@type": "Person",
		name: "Santiago Carrasco",
		url: homeURL,
	},
	speakable: {
		"@type": "SpeakableSpecification",
		cssSelector: ["[data-article-headline]", "[data-article-summary]"],
	},
	...(entry.data.keywords
		? {
				keywords: entry.data.keywords.join(", "),
			}
		: {}),
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{
			"@type": "ListItem",
			position: 1,
			name: entry.data.lang === "es" ? "Inicio" : "Home",
			item: homeURL,
		},
		{
			"@type": "ListItem",
			position: 2,
			name: entry.data.title,
		},
	],
};

const alternates =
	entry.data.lang === "es"
		? { es: canonicalURL, "x-default": canonicalURL }
		: { en: canonicalURL, "x-default": canonicalURL };

const { Content, headings, remarkPluginFrontmatter } = await render(entry);
const mdxComponents = { Note };
const isMdx = entry.id.toLowerCase().endsWith(".mdx");
const readingMeta = remarkPluginFrontmatter.minutesRead as
	| { minutes?: number }
	| undefined;
const fallbackWords = (entry.body ?? "")
	.trim()
	.split(/\s+/u)
	.filter(Boolean).length;
const fallbackMinutes = Math.max(1, Math.ceil(fallbackWords / 220));
const minutesRead = Math.max(
	1,
	Math.ceil(readingMeta?.minutes ?? fallbackMinutes),
);
const readingTime = {
	minutes: minutesRead,
	text:
		entry.data.lang === "es"
			? `${minutesRead} min de lectura`
			: `${minutesRead} min read`,
};
---

<BlogLayout
  title={entry.data.title}
  description={entry.data.description}
  image={imageURL}
  url={canonicalURL}
  lang={entry.data.lang}
  alternates={alternates}
  schema={[articleSchema, breadcrumbSchema]}
>
  <BlogContent
    post={entry.data}
    id={normalizedId}
    headings={headings}
    readingTime={readingTime}
    canonicalURL={canonicalURL}
  >
    {isMdx ? <Content components={mdxComponents} /> : <Content />}
  </BlogContent>
</BlogLayout>
