---
export const prerender = false;

import { render } from "astro:content";
import Note from "@components/mdx/Note.astro";
import BlogContent from "@components/pages/Blog/index.astro";
import BlogLayout from "@layouts/Blog.astro";
import { getLocaleHomeUrl } from "@ts/i18n";
import { resolvePostPage } from "@ts/post-page";

const siteURL = Astro.site ?? Astro.url;
const page = await resolvePostPage({
	locale: "es",
	id: Astro.params.id,
	siteURL,
});

if (page.type === "redirect") {
	return Astro.redirect(page.location, page.status);
}

if (page.type === "not-found") {
	return Astro.redirect("/es/404");
}

const {
	entry,
	slug,
	homeHref,
	canonicalURL,
	imageURL,
	authorImageURL,
	relativeAlternates,
	absoluteAlternates,
} = page;

const homeURL = new URL(getLocaleHomeUrl(entry.data.lang), siteURL).toString();

const articleSchema = {
	"@context": "https://schema.org",
	"@type": "Article",
	headline: entry.data.title,
	description: entry.data.description,
	image: [imageURL],
	datePublished: entry.data.pubDate.toISOString(),
	dateModified: (entry.data.updatedDate ?? entry.data.pubDate).toISOString(),
	inLanguage: entry.data.lang === "es" ? "es-MX" : "en-US",
	articleSection: entry.data.categories,
	mainEntityOfPage: {
		"@type": "WebPage",
		"@id": canonicalURL,
	},
	author: {
		"@type": "Person",
		name: entry.data.author.name,
		image: authorImageURL,
		url: homeURL,
	},
	publisher: {
		"@type": "Person",
		name: "Santiago Carrasco",
		url: homeURL,
	},
	speakable: {
		"@type": "SpeakableSpecification",
		cssSelector: ["[data-article-headline]", "[data-article-summary]"],
	},
	keywords: entry.data.keywords.join(", "),
};

const faqSchema =
	entry.data.faq && entry.data.faq.length > 0
		? {
				"@context": "https://schema.org",
				"@type": "FAQPage",
				mainEntity: entry.data.faq.map(({ q, a }) => ({
					"@type": "Question",
					name: q,
					acceptedAnswer: {
						"@type": "Answer",
						text: a,
					},
				})),
			}
		: null;

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{
			"@type": "ListItem",
			position: 1,
			name: entry.data.lang === "es" ? "Inicio" : "Home",
			item: homeURL,
		},
		{
			"@type": "ListItem",
			position: 2,
			name: entry.data.title,
		},
	],
};

const alternates = {
	...absoluteAlternates,
	"x-default": absoluteAlternates.en ?? canonicalURL,
};

const languageSwitcher = relativeAlternates.es ? relativeAlternates : undefined;

const { Content, headings, remarkPluginFrontmatter } = await render(entry);
const mdxComponents = { Note };
const isMdx = entry.id.toLowerCase().endsWith(".mdx");
const readingMeta = remarkPluginFrontmatter.minutesRead as
	| { minutes?: number }
	| undefined;
const fallbackWords = (entry.body ?? "")
	.trim()
	.split(/\s+/u)
	.filter(Boolean).length;
const fallbackMinutes = Math.max(1, Math.ceil(fallbackWords / 220));
const minutesRead = Math.max(
	1,
	Math.ceil(readingMeta?.minutes ?? fallbackMinutes),
);
const readingTime = {
	minutes: minutesRead,
	text:
		entry.data.lang === "es"
			? `${minutesRead} min de lectura`
			: `${minutesRead} min read`,
};
---

<BlogLayout
  title={entry.data.title}
  description={entry.data.description}
  image={imageURL}
  url={canonicalURL}
  lang={entry.data.lang}
  alternates={alternates}
  languageSwitcher={languageSwitcher}
  schema={[articleSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])]}
>
  <BlogContent
    post={entry.data}
    id={slug}
    headings={headings}
    readingTime={readingTime}
    canonicalURL={canonicalURL}
    homeHref={homeHref}
  >
    {isMdx ? <Content components={mdxComponents} /> : <Content />}
  </BlogContent>
</BlogLayout>
