---
import BaseLayout from "@layouts/Base.astro";
import { getLocaleHomeUrl } from "@ts/i18n";
import { getLocaleMessages } from "../../i18n";

const lang = "es";
const messages = getLocaleMessages(lang);
const siteURL = Astro.site ?? Astro.url;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();
---

<BaseLayout
  lang={lang}
  noIndex
  title={messages.notFound.metaTitle}
  description={messages.notFound.metaDescription}
  url={canonicalURL}
>
  <div class="flex flex-col items-center justify-center gap-6 py-20 text-center">
    <h1 class="text-display font-semibold text-ink">{messages.notFound.title}</h1>
    <p class="m-0 text-ink-muted text-lg max-w-[40ch]">
      {messages.notFound.description}
    </p>
    <a
      href={getLocaleHomeUrl(lang)}
      class="inline-flex items-center gap-2 text-brand font-semibold no-underline hover:underline"
    >
      {messages.notFound.cta}
    </a>
  </div>
</BaseLayout>
