---
import HomeContent from "@components/pages/Home/index.astro";
import BaseLayout from "@layouts/Base.astro";
import { getLocaleHomeUrl } from "@ts/i18n";
import { getLocaleMessages } from "../../i18n";

const lang = "es";
const messages = getLocaleMessages(lang);
const siteURL = Astro.site ?? Astro.url;
const canonicalURL = new URL(getLocaleHomeUrl(lang), siteURL).toString();
const englishURL = new URL(getLocaleHomeUrl("en"), siteURL).toString();
const pageDescription = messages.home.pageDescription;

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Santiago Carrasco",
	alternateName: "Santychuy",
	url: canonicalURL,
	image: new URL("/imgs/profile.jpg", siteURL).toString(),
	sameAs: ["https://github.com/santychuycom", "https://x.com/santychuy"],
};

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: "Santiago Carrasco (Santychuy)",
	url: canonicalURL,
	description: pageDescription,
	publisher: {
		"@type": "Person",
		name: "Santiago Carrasco",
	},
	inLanguage: "es-MX",
};
---

<BaseLayout
  lang={lang}
  description={pageDescription}
  url={canonicalURL}
  alternates={{ en: englishURL, es: canonicalURL, 'x-default': englishURL }}
  languageSwitcher={{ en: getLocaleHomeUrl('en'), es: getLocaleHomeUrl('es') }}
  schema={[websiteSchema, personSchema]}
>
  <HomeContent lang={lang} />
</BaseLayout>
